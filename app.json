{
  "expo": {
    "name": "video-camera-chat",
    "slug": "video-camera-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/images/png/logo.png",
    "scheme": "ab-uipl-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "remote-notification"],
        "NSCameraUsageDescription": "$(PRODUCT_NAME) needs access to your Camera.",
        "NSMicrophoneUsageDescription": "$(PRODUCT_NAME) needs access to your Microphone.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.uipl.videocamerachat"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./app/assets/images/png/logo.png",
        "backgroundImage": "./app/assets/images/png/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC"
      ],
      "package": "com.uipl.videocamerachat"
    },
    "web": {
      "output": "single",
      "favicon": "./app/assets/images/png/favicon.png"
    },
    "plugins": [
      "./plugins/backgroundActions.js",
      "./plugins/withMergedMlKitDependencies.js",
      "react-native-compressor",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "$(PRODUCT_NAME) needs access to your Camera.",
          "enableMicrophonePermission": true,
          "microphonePermissionText": "$(PRODUCT_NAME) needs access to your Microphone."
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      [
        "react-native-fast-tflite",
        {
          "enableAndroidGpuLibraries": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./app/assets/images/png/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-video",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.6"
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "11eaa553-1487-4fdc-af20-627c01589a56"
      }
    }
  }
}
